{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": true,
  "separate-pull-requests": true,
  "bump-minor-pre-major": true,
  "packages": {
    "plugins/pre-pmf-starter": {
      "package-name": "pre-pmf-starter",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/expert-onboarding": {
      "package-name": "expert-onboarding",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
